{
  "expo": {
    "name": "Spy Game",
    "slug": "spy-game",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.spygame"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.spygame",
      "minSdkVersion": 21,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "buildType": "release",
      "gradle": {
        "properties": [
          "org.gradle.jvmargs=-Xmx4096m",
          "android.useAndroidX=true",
          "android.enableJetifier=true",
          "android.enableNewResourceIdGenerator=true"
        ]
      }
    },
    "web": {
      "favicon": ""
    }
  }
}
